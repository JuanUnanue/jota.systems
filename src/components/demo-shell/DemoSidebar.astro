---
import DemoLogo from './DemoLogo.astro';

export interface MenuItem {
  href: string;
  label: string;
  icon: string; // SVG path data
  match: string; // path prefix para el active; 'NEVER' = nunca activo
  external?: boolean; // abre en nueva pestaña, sin estado disabled
}

export interface Brand {
  href: string;
  mark: string;
  name: string;
  sub: string;
  ariaLabel?: string;
}

export interface User {
  initials: string;
  name: string;
  role: string;
}

export interface Props {
  current?: string; // pathname para marcar el activo
  brand: Brand;
  user: User;
  logoutHref: string;
  menuItems: MenuItem[];
  // Cuántos items van bajo el primer label ("Operación") — el resto va bajo "Gestión"
  primaryCount?: number;
  primaryLabel?: string;
  secondaryLabel?: string;
}

const {
  current = '',
  brand,
  user,
  logoutHref,
  menuItems,
  primaryCount = 3,
  primaryLabel = 'Operación',
  secondaryLabel = 'Gestión',
} = Astro.props;

const isActive = (item: { match: string }) =>
  item.match !== 'NEVER' && current.startsWith(item.match);

const primary = menuItems.slice(0, primaryCount);
const secondary = menuItems.slice(primaryCount);
---

<aside class="demo-sidebar" aria-label="Navegación del sistema">
  <DemoLogo href={brand.href} mark={brand.mark} name={brand.name} sub={brand.sub} ariaLabel={brand.ariaLabel} />

  <nav class="demo-nav" aria-label="Módulos">
    <p class="demo-nav-section-label">{primaryLabel}</p>
    <ul class="demo-nav-list">
      {primary.map((item) => (
        <li>
          <a href={item.href} class={isActive(item) ? 'active' : ''}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon} />
            </svg>
            <span>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>

    {secondary.length > 0 && (
      <>
        <p class="demo-nav-section-label" style="margin-top:1.25rem;">{secondaryLabel}</p>
        <ul class="demo-nav-list">
          {secondary.map((item) => (
            <li>
              {item.external ? (
                <a href={item.href} target="_blank" rel="noopener" class="external">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d={item.icon} />
                  </svg>
                  <span>{item.label}</span>
                  <svg class="ext-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7M7 7h10v10"/>
                  </svg>
                </a>
              ) : item.match === 'NEVER' ? (
                <a href={item.href} class="disabled" aria-disabled="true" tabindex="-1">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d={item.icon} />
                  </svg>
                  <span>{item.label}</span>
                </a>
              ) : (
                <a href={item.href} class={isActive(item) ? 'active' : ''}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d={item.icon} />
                  </svg>
                  <span>{item.label}</span>
                </a>
              )}
            </li>
          ))}
        </ul>
      </>
    )}
  </nav>

  <div class="demo-sidebar-foot">
    <span class="demo-user-avatar">{user.initials}</span>
    <span class="demo-user-info">
      <span class="demo-user-name">{user.name}</span>
      <span class="demo-user-rol">{user.role}</span>
    </span>
    <a href={logoutHref} class="demo-logout" aria-label="Salir">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" />
      </svg>
    </a>
  </div>
</aside>
