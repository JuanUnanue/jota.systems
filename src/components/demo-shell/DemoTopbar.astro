---
export interface Props {
  title: string;
  searchPlaceholder?: string;
}

const { title, searchPlaceholder = 'Buscar…' } = Astro.props;
---

<header class="demo-topbar">
  <button
    type="button"
    class="demo-menu-toggle"
    id="demo-menu-toggle"
    aria-label="Abrir menú"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="6" x2="21" y2="6" />
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="18" x2="21" y2="18" />
    </svg>
  </button>

  <h1 class="demo-topbar-title">{title}</h1>

  <div class="demo-topbar-search">
    <span class="demo-topbar-search-icon">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </span>
    <input type="search" placeholder={searchPlaceholder} aria-label="Búsqueda global" />
  </div>

  <div class="demo-topbar-actions">
    <button type="button" class="demo-icon-btn" aria-label="Notificaciones">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
      <span class="badge-dot"></span>
    </button>
    <button type="button" class="demo-icon-btn" aria-label="Ayuda">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
    </button>
  </div>
</header>
