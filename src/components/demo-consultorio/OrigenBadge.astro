---
import type { OrigenTurno } from '../../data/consultorio';

export interface Props {
  origen: OrigenTurno;
  size?: 'sm' | 'md';
}

const { origen, size = 'sm' } = Astro.props;
---

{origen === 'online-nuevo' && (
  <span
    class={`origen-badge origen-${size}`}
    title="Reservado online · primera consulta · seña pagada"
    aria-label="Reservado online · primera consulta · seña pagada"
  >
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
    </svg>
    <span class="origen-text">Online + seña</span>
  </span>
)}

<style>
  .origen-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    border: 1px solid;
    background: rgba(40, 130, 70, 0.10);
    color: #2D7A48;
    border-color: rgba(40, 130, 70, 0.25);
  }

  .origen-sm {
    font-size: 0.62rem;
    letter-spacing: 0.02em;
    padding: 0.15rem 0.4rem;
  }

  .origen-md {
    font-size: 0.7rem;
    letter-spacing: 0.03em;
    padding: 0.25rem 0.5rem;
  }
</style>
