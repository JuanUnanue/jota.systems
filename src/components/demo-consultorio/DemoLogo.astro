---
export interface Props {
  href?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { href = '/demos/consultorio/dashboard', size = 'md' } = Astro.props;

const sizes = {
  sm: { mark: 32, name: '0.95rem', sub: '0.6rem' },
  md: { mark: 38, name: '1rem', sub: '0.65rem' },
  lg: { mark: 56, name: '1.4rem', sub: '0.75rem' },
};
const s = sizes[size];
---

<a href={href} class="demo-logo-link" aria-label="Ache Odontología — ir al dashboard">
  <span
    class="demo-logo-mark"
    style={`width:${s.mark}px;height:${s.mark}px;font-size:${size === 'lg' ? '1.2rem' : '0.95rem'};`}
  >Ac</span>
  <span class="demo-logo-text">
    <span class="demo-logo-name" style={`font-size:${s.name}`}>Ache</span>
    <span class="demo-logo-sub" style={`font-size:${s.sub}`}>Odontología</span>
  </span>
</a>
