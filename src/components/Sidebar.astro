---
const navItems = [
  { label: 'Sobre el estudio', href: '#sobre-mi' },
  { label: 'Proyectos', href: '#proyectos' },
  { label: 'Contacto', href: '#contacto' },
];
---

<aside class="sidebar">
  <div class="sidebar-inner">
    <div>
      <a href="/" class="brand-link">
        <img src="/logo-main.svg" alt="CodeMar" class="brand-logo" />
        <div class="brand-text">
          <h1 class="brand-title">CodeMar</h1>
          <p class="title">Desarrollador web & sistemas</p>
          <p class="intro">
            Construyo sitios y sistemas a medida para negocios que quieren operar mejor.
          </p>
        </div>
      </a>

      <nav class="sidebar-nav">
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href}>
                <span class="nav-line"></span>
                <span class="nav-label">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="sidebar-footer">
      <div class="socials">
        <a href="https://github.com/JuanUnanue" target="_blank" rel="noopener" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/unanuejuan" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="mailto:hola@codemar.com.ar" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <a href="https://wa.me/5492236015427" target="_blank" rel="noopener" aria-label="WhatsApp">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>
        </a>
      </div>

      <div class="status">
        <span class="status-dot"></span>
        <span>Disponible para nuevos proyectos</span>
      </div>

      <p class="brand-meta">CodeMar</p>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    padding: 6rem 0;
    display: flex;
    align-items: flex-start;
  }

  .sidebar-inner {
    max-height: calc(100vh - 12rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    overflow-y: auto;
  }

  .sidebar-inner::-webkit-scrollbar { width: 0; }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .brand-logo {
    display: block;
    width: 150px;
    height: auto;
    flex-shrink: 0;
    transition: transform var(--transition);
  }

  .brand-link:hover .brand-logo {
    transform: scale(1.05) rotate(-2deg);
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .brand-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0;
    transition: color var(--transition);
  }

  .brand-link:hover .brand-title {
    color: var(--accent);
  }

  .brand-link:hover .title {
    color: var(--accent);
  }

  .title {
    font-size: 1.15rem;
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0;
    transition: color var(--transition);
  }

  .intro {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.5;
    margin: 0;
  }

  /* Nav con líneas que crecen al hover */
  .sidebar-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-nav a {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .nav-line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: var(--text-muted);
    transition: all var(--transition);
  }

  .sidebar-nav a:hover,
  .sidebar-nav a.active {
    color: var(--text-primary);
  }

  .sidebar-nav a:hover .nav-line,
  .sidebar-nav a.active .nav-line {
    width: 64px;
    background: var(--text-primary);
  }

  /* Footer del sidebar */
  .sidebar-footer {
    margin-top: 3rem;
  }

  .socials {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .socials a {
    color: var(--text-muted);
    transition: all var(--transition);
    display: inline-flex;
  }

  .socials a:hover {
    color: var(--accent);
    transform: translateY(-3px);
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .brand-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .sidebar {
      position: relative;
      height: auto;
      padding: 4rem 0 2rem;
    }
    .sidebar-inner {
      max-height: none;
    }
    .intro { max-width: 100%; }
  }

  @media (max-width: 640px) {
    .socials { gap: 1rem; }
  }
</style>
