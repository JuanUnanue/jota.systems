---
const projects = [
  {
    slug: 'senderos-de-la-costa',
    name: 'Senderos de la Costa',
    year: '2025',
    category: 'Sistema de Gestión',
    description: 'Sistema de gestión integral construido a medida para digitalizar y automatizar los procesos administrativos y operativos del negocio.',
    tech: ['Angular', 'Node.js', 'PostgreSQL', 'Docker'],
    links: {
      external: '#',
      demo: '/proyectos/senderos-de-la-costa#demo',
      caseStudy: '/proyectos/senderos-de-la-costa'
    },
    highlight: 'Reducción del 70% en tareas admin'
  },
  {
    slug: 'alojamiento-calma',
    name: 'Alojamiento Calma',
    year: '2024',
    category: 'Sitio Web',
    description: 'Sitio web para alojamiento turístico con diseño que refleja la identidad del lugar. Formulario de consultas con notificaciones automáticas y galería optimizada.',
    tech: ['HTML/CSS', 'JavaScript', 'Netlify'],
    links: {
      external: '#',
      caseStudy: '/proyectos/alojamiento-calma'
    },
    highlight: '+3× consultas recibidas'
  }
];
---

<section id="proyectos" class="projects">
  <h2>Proyectos Destacados</h2>
  <div class="projects-list">
    {projects.map((project) => (
      <a href={project.links.caseStudy} class="project-card">
        <div class="project-thumb">
          <div class="thumb-inner">
            <span class="thumb-label">{project.name}</span>
          </div>
        </div>
        <div class="project-body">
          <div class="project-header">
            <p class="project-meta">{project.year} · {project.category}</p>
            <div class="project-links">
              {project.links.external && (
                <span class="icon-link" title="Sitio externo">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </span>
              )}
              {project.links.demo && (
                <span class="icon-link" title="Demo">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </span>
              )}
            </div>
          </div>
          <h3 class="project-name">
            {project.name} <span class="arrow">↗</span>
          </h3>
          <p class="project-desc">{project.description}</p>
          <div class="project-highlight">
            <span class="mono">→</span> {project.highlight}
          </div>
          <ul class="project-tech">
            {project.tech.map((t) => <li>{t}</li>)}
          </ul>
        </div>
      </a>
    ))}
  </div>

  <div class="archive-link">
    <a href="#" class="link-inline">Ver archivo completo <span class="arrow-inline">→</span></a>
  </div>
</section>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 1rem;
    margin: 0 -1rem;
    border-radius: 8px;
    border: 1px solid transparent;
    color: inherit;
    transition: all var(--transition);
    position: relative;
  }

  /* Focus on hover: al hover sobre la lista, las cards no-hovered se difuminan */
  @media (hover: hover) {
    .projects-list:hover .project-card:not(:hover) {
      opacity: 0.2;
    }
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background: transparent;
    transition: background var(--transition);
    z-index: -1;
    pointer-events: none;
  }

  .project-card:hover::before {
    background: var(--bg-panel);
  }

  .project-card:hover {
    border-color: var(--border);
    transform: translateY(-2px);
  }

  .project-card:hover .project-name,
  .project-card:hover .project-name .arrow {
    color: var(--accent);
  }

  .project-card:hover .project-name .arrow {
    transform: translate(3px, -3px);
  }

  /* Thumb visual */
  .project-thumb {
    aspect-ratio: 16 / 9;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color var(--transition);
  }

  .project-card:hover .project-thumb {
    border-color: var(--border-strong);
  }

  .thumb-inner {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--bg-panel) 0%, var(--bg-panel-hover) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .thumb-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(232, 184, 118, 0.08), transparent 60%);
  }

  .thumb-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    position: relative;
    z-index: 1;
  }

  /* Project body */
  .project-body {
    display: flex;
    flex-direction: column;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .project-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
  }

  .project-links {
    display: flex;
    gap: 0.5rem;
  }

  .icon-link {
    display: inline-flex;
    padding: 0.25rem;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .project-card:hover .icon-link { color: var(--accent); }

  .project-name {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.6rem;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    transition: color var(--transition);
  }

  .project-name .arrow {
    display: inline-block;
    font-size: 0.9rem;
    transition: transform var(--transition), color var(--transition);
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.85rem;
  }

  .project-highlight {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: 1rem;
    padding: 0.4rem 0.75rem;
    background: var(--accent-dim);
    border-radius: 4px;
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
  }

  .project-tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-tech li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    padding: 0.25rem 0.65rem;
    background: var(--accent-dim);
    border-radius: 999px;
    font-weight: 500;
  }

  .archive-link {
    margin-top: 1rem;
  }

  .arrow-inline {
    display: inline-block;
    transition: transform var(--transition);
  }

  .archive-link a:hover .arrow-inline {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .project-card { grid-template-columns: 1fr; }
    .project-thumb { max-width: 280px; }
  }
</style>
