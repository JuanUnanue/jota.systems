---
import type { EstadoSanitario } from '../../data/veterinaria';
import { fechaCorta } from '../../data/veterinaria';

interface Item {
  nombre: string;
  ultimaAplicacion: string;
  proximaAplicacion: string;
  estado: EstadoSanitario;
  observaciones?: string;
  via?: 'interno' | 'externo';
}

export interface Props {
  titulo: string;
  items: Item[];
  ctaLabel?: string;
  agruparPorVia?: boolean; // para antiparasitarios
}

const { titulo, items, ctaLabel, agruparPorVia = false } = Astro.props;

const labelEstado: Record<EstadoSanitario, string> = {
  'al-dia': 'Al día',
  'proxima': 'Próxima',
  'vencida': 'Vencida',
  'no-aplica': '—',
};

const grupos = agruparPorVia
  ? [
      { titulo: 'Internos', items: items.filter((i) => i.via === 'interno') },
      { titulo: 'Externos', items: items.filter((i) => i.via === 'externo') },
    ].filter((g) => g.items.length > 0)
  : [{ titulo: '', items }];
---

<div class="cal-sanitario">
  <div class="cal-head">
    <h3>{titulo}</h3>
    {ctaLabel && (
      <button type="button" class="cal-cta">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        {ctaLabel}
      </button>
    )}
  </div>

  {grupos.map((grupo) => (
    <div class="cal-grupo">
      {grupo.titulo && <p class="cal-grupo-titulo">{grupo.titulo}</p>}
      <ul class="cal-list" role="list">
        {grupo.items.map((it) => (
          <li class={`cal-row cal-${it.estado}`}>
            <span class="cal-nombre">{it.nombre}</span>
            <span class="cal-fechas">
              <span class="cal-fecha-label">Última</span>
              <span class="cal-fecha-val">{it.ultimaAplicacion ? fechaCorta(it.ultimaAplicacion) : '—'}</span>
            </span>
            <span class="cal-fechas">
              <span class="cal-fecha-label">Próxima</span>
              <span class="cal-fecha-val">{fechaCorta(it.proximaAplicacion)}</span>
            </span>
            <span class={`cal-pill cal-pill-${it.estado}`}>{labelEstado[it.estado]}</span>
            {it.observaciones && <span class="cal-obs">⚠ {it.observaciones}</span>}
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>

<style>
  .cal-sanitario {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .cal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .cal-head h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .cal-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.75rem;
    border: 1px dashed var(--border-strong);
    background: var(--bg);
    color: var(--accent);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.03em;
    transition: all var(--transition);
  }

  .cal-cta:hover {
    border-style: solid;
    background: var(--accent-dim);
  }

  .cal-grupo-titulo {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 0.4rem;
  }

  .cal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cal-row {
    display: grid;
    grid-template-columns: minmax(120px, 1.6fr) minmax(90px, 1fr) minmax(90px, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.7rem 0.85rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    border-left-width: 3px;
  }

  .cal-row.cal-al-dia { border-left-color: #2D7A48; }
  .cal-row.cal-proxima { border-left-color: var(--accent); }
  .cal-row.cal-vencida { border-left-color: #B23A3A; background: rgba(217, 80, 80, 0.04); }
  .cal-row.cal-no-aplica { border-left-color: var(--text-muted); opacity: 0.7; }

  .cal-nombre {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.92rem;
  }

  .cal-fechas {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.2;
  }

  .cal-fecha-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .cal-fecha-val {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  .cal-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    border-radius: 999px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .cal-pill-al-dia { background: rgba(40, 130, 70, 0.12); color: #2D7A48; }
  .cal-pill-proxima { background: rgba(184, 83, 15, 0.10); color: var(--accent); }
  .cal-pill-vencida { background: rgba(217, 80, 80, 0.14); color: #B23A3A; }
  .cal-pill-no-aplica { background: rgba(42, 29, 18, 0.06); color: var(--text-muted); }

  .cal-obs {
    grid-column: 1 / -1;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    margin-top: 0.3rem;
  }

  /* Responsive — en mobile colapsamos a 2 columnas */
  @media (max-width: 640px) {
    .cal-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      row-gap: 0.5rem;
    }

    .cal-nombre { grid-column: 1 / 2; grid-row: 1; }
    .cal-pill { grid-column: 2; grid-row: 1; justify-self: end; }
    .cal-fechas:nth-of-type(1) { grid-column: 1 / 2; grid-row: 2; flex-direction: row; gap: 0.4rem; }
    .cal-fechas:nth-of-type(2) { grid-column: 2; grid-row: 2; flex-direction: row; gap: 0.4rem; }
  }
</style>
