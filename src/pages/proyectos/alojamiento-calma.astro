---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Alojamiento Calma — CodeMar"
  description="Sitio web para un alojamiento turístico familiar en Mar del Plata. Dos departamentos a pasos del mar, diseñado para captar reservas directas por WhatsApp."
  showSidebar={false}
>
  <article class="case-detail">
    <div class="case-page">
      <a href="/#proyectos" class="back-link">← Volver al inicio</a>

      <header class="case-header">
        <p class="eyebrow">Sitio Web</p>
        <h1>Alojamiento Calma</h1>
        <p class="case-intro">
          Sitio web para un alojamiento turístico familiar. <span class="text-primary">Dos departamentos a pasos del mar</span> en Mar del Plata, con foco en captar reservas directas por WhatsApp.
        </p>
        <div class="case-actions">
          <a href="https://www.alojamientocalma.com.ar/" target="_blank" rel="noopener" class="btn btn-solid">Ver sitio en vivo ↗</a>
        </div>
      </header>

      <section class="block" id="que-es">
        <h2>Qué es</h2>
        <p>
          Sitio web para un alojamiento de dos departamentos en la costa de Mar del Plata. El diseño refleja la identidad tranquila y familiar del lugar, con tipografías serif elegantes, paleta cálida y mucha fotografía real de los espacios.
        </p>
        <p>
          La conversión principal es <span class="text-primary">un mensaje por WhatsApp</span>. Todo el sitio guía al visitante hacia ese punto — consulta disponibilidad, precios, y se cierra la reserva en minutos, sin intermediarios ni comisiones de plataformas externas.
        </p>
        <p>
          Diseñado mobile-first: más del 70% de las consultas de alojamiento turístico llegan desde el teléfono. Carga rápido, navega fluido, y convierte al click del botón.
        </p>
      </section>

      <section class="block" id="stack">
        <h2>Stack técnico</h2>
        <ul class="tech-tags">
          <li>HTML5</li>
          <li>CSS3</li>
          <li>JavaScript</li>
          <li>Google Maps API</li>
          <li>WhatsApp Click-to-Chat</li>
          <li>Vercel</li>
        </ul>
      </section>

      <section class="block cta-section">
        <h3>¿Querés algo similar para tu negocio?</h3>
        <a href="/#contacto" class="btn btn-solid">Contactame</a>
      </section>

      <Footer />
    </div>
  </article>
</Layout>

<style>
  .case-detail {
    max-width: 780px;
    margin: 0 auto;
    padding: 2.5rem 0 0;
    color: var(--text-secondary);
  }

  .case-page {
    padding: 0 1.5rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .back-link:hover { color: var(--accent-hover); }

  /* HEADER */
  .case-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.75rem;
  }

  .case-header h1 {
    margin-bottom: 1rem;
    font-size: clamp(2.25rem, 4vw, 3rem);
  }

  .case-intro {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 1.5rem;
    max-width: 680px;
  }

  .case-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* BLOCKS */
  .block {
    margin-bottom: 0.5rem;
  }

  .block h2 {
    margin-bottom: 0.5rem;
    margin-top: 0;
  }

  .block p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 0;
  }

  .block p + p {
    margin-top: 0.5rem;
  }

  /* TECH TAGS */
  .tech-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tech-tags li {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 999px;
    font-weight: 500;
  }

  /* CTA */
  .cta-section {
    text-align: center;
    padding: 2rem 1.5rem;
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-top: 2.5rem;
  }

  .cta-section h3 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .case-page { padding: 0 1.25rem; }
    .case-header h1 { font-size: 2rem; }
  }
</style>
