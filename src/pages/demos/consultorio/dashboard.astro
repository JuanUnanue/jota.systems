---
import DemoConsultorioLayout from '../../../layouts/DemoConsultorioLayout.astro';
import OrigenBadge from '../../../components/demo-consultorio/OrigenBadge.astro';
import {
  kpis,
  turnosHoy,
  proximosTurnos,
  alertas,
} from '../../../data/consultorio';

// Hoy es jueves 30 de abril de 2026
const fechaHoy = 'Jueves 30 de abril de 2026';

// Agrupar próximos turnos por fecha
const turnosPorFecha = proximosTurnos.reduce((acc, t) => {
  (acc[t.fecha] ||= []).push(t);
  return acc;
}, {} as Record<string, typeof proximosTurnos>);

const fechaCorta = (iso: string) => {
  const [y, m, d] = iso.split('-').map(Number);
  const date = new Date(y, m - 1, d);
  const dias = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
  const meses = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
  return `${dias[date.getDay()]} ${d} ${meses[m - 1]}`;
};

const iconoAlerta: Record<string, string> = {
  'reserva-online':
    'M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0zM3.6 9h16.8M3.6 15h16.8M11.5 3a17 17 0 0 0 0 18M12.5 3a17 17 0 0 1 0 18',
  'control-vencido':
    'M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01',
  'cumpleanos':
    'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z',
  'tratamiento-en-curso':
    'M22 12h-4l-3 9L9 3l-3 9H2',
};
---

<DemoConsultorioLayout
  title="Dashboard — Ache Odontología"
  pageTitle="Dashboard"
>
  <div class="page-head">
    <div>
      <h1>Hola, Dra. Mercedes 👋</h1>
      <p class="subtitle">{fechaHoy}</p>
    </div>
    <div class="page-head-actions">
      <a href="/demos/consultorio/agenda" class="btn-app">Ver agenda completa</a>
      <a href="#" class="btn-app primary">+ Nuevo turno</a>
    </div>
  </div>

  <!-- KPIs -->
  <section class="kpi-grid">
    {kpis.map((k) => (
      <div class="kpi-card">
        <div class="kpi-label">{k.label}</div>
        <div class="kpi-value">
          {k.valor}
          {k.trend === 'up' && (
            <span class="kpi-trend up" aria-label="tendencia al alza">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 15 12 9 18 15"/>
              </svg>
            </span>
          )}
          {k.trend === 'down' && (
            <span class="kpi-trend down" aria-label="tendencia a la baja">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          )}
        </div>
        <div class="kpi-detail">{k.detalle}</div>
      </div>
    ))}
  </section>

  <!-- Turnos hoy + Alertas -->
  <section class="dash-row">
    <div class="card dash-turnos">
      <div class="card-head">
        <h2 class="card-title">Turnos de hoy</h2>
        <a href="/demos/consultorio/agenda" class="card-link">Ver agenda →</a>
      </div>
      <ul class="turnos-list">
        {turnosHoy.map((t) => (
          <li class={`turno-row turno-${t.estado}`}>
            <span class="turno-hora">{t.hora}</span>
            <div class="turno-info">
              <div class="turno-paciente-row">
                {t.pacienteSlug === '#' ? (
                  <span class="turno-paciente turno-paciente-nuevo">
                    {t.pacienteNombre}
                    <span class="turno-nuevo-tag">nuevo</span>
                  </span>
                ) : (
                  <a href={`/demos/consultorio/pacientes/${t.pacienteSlug}`} class="turno-paciente">
                    {t.pacienteNombre}
                  </a>
                )}
                <OrigenBadge origen={t.origen} />
              </div>
              <span class="turno-procedimiento">{t.procedimiento}</span>
              {t.notas && <span class="turno-nota">⚠ {t.notas}</span>}
            </div>
            <span class={`pill pill-${t.estado}`}>
              {t.estado === 'en-sala' ? 'En sala' : t.estado === 'finalizado' ? 'Hecho' : 'Confirmado'}
            </span>
          </li>
        ))}
      </ul>
    </div>

    <div class="card dash-alertas">
      <div class="card-head">
        <h2 class="card-title">Alertas</h2>
        <span class="card-link">{alertas.length} sin leer</span>
      </div>
      <ul class="alertas-list">
        {alertas.map((a) => (
          <li class={`alerta alerta-${a.tipo}`}>
            <span class="alerta-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconoAlerta[a.tipo]} />
              </svg>
            </span>
            <div>
              <span class="alerta-text">{a.texto}</span>
              {a.detalle && <span class="alerta-detalle">{a.detalle}</span>}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Próximos turnos -->
  <section class="card dash-proximos">
    <div class="card-head">
      <h2 class="card-title">Próximos turnos</h2>
      <a href="/demos/consultorio/agenda" class="card-link">Ver semana →</a>
    </div>
    <div class="proximos-grid">
      {Object.entries(turnosPorFecha).map(([fecha, lista]) => (
        <div class="proximo-dia">
          <div class="proximo-dia-head">
            <span class="proximo-dia-fecha">{fechaCorta(fecha)}</span>
            <span class="proximo-dia-count">{lista.length} turno{lista.length !== 1 ? 's' : ''}</span>
          </div>
          <ul class="proximo-list">
            {lista.map((t) => (
              <li>
                <span class="proximo-hora">{t.hora}</span>
                {t.pacienteSlug === '#' ? (
                  <span class="proximo-paciente proximo-paciente-nuevo">
                    {t.pacienteNombre}
                  </span>
                ) : (
                  <a href={`/demos/consultorio/pacientes/${t.pacienteSlug}`} class="proximo-paciente">
                    {t.pacienteNombre}
                  </a>
                )}
                <span class="proximo-proc">
                  {t.procedimiento}
                  {t.origen !== 'manual' && (
                    <OrigenBadge origen={t.origen} />
                  )}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</DemoConsultorioLayout>

<style>
  /* KPI grid */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .kpi-card {
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    transition: all var(--transition);
  }

  .kpi-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }

  .kpi-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
  }

  .kpi-value {
    font-size: 1.85rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .kpi-trend {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .kpi-trend.up {
    background: rgba(40, 130, 70, 0.12);
    color: #2D7A48;
  }

  .kpi-trend.down {
    background: rgba(217, 80, 80, 0.12);
    color: #B23A3A;
  }

  .kpi-detail {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  /* Row Turnos + Alertas */
  .dash-row {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  /* Turnos hoy */
  .turnos-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .turno-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 0.85rem 0;
    border-top: 1px solid var(--border);
  }

  .turno-row:first-child { border-top: none; }

  .turno-finalizado {
    opacity: 0.55;
  }

  .turno-finalizado .turno-paciente {
    text-decoration: line-through;
    text-decoration-color: var(--text-muted);
  }

  .turno-en-sala {
    background: linear-gradient(90deg, rgba(184, 83, 15, 0.06), transparent 70%);
    border-radius: 6px;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    margin: 0 -0.75rem;
  }

  .turno-hora {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    min-width: 50px;
  }

  .turno-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .turno-paciente-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .turno-paciente {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  a.turno-paciente:hover {
    color: var(--accent);
  }

  .turno-nuevo-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    background: var(--accent);
    color: var(--bg);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .proximo-paciente-nuevo {
    color: var(--accent);
  }

  .proximo-proc {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .turno-procedimiento {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .turno-nota {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    margin-top: 0.15rem;
  }

  /* Alertas */
  .alertas-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .alerta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 8px;
    background: var(--bg);
    border-left: 3px solid var(--text-muted);
  }

  .alerta div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .alerta-control-vencido { border-left-color: #B23A3A; }
  .alerta-presupuesto-pendiente { border-left-color: var(--accent); }
  .alerta-cumpleanos { border-left-color: #2D7A48; }
  .alerta-tratamiento-en-curso { border-left-color: var(--text-secondary); }

  .alerta-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--bg-panel);
    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .alerta-control-vencido .alerta-icon { color: #B23A3A; }
  .alerta-presupuesto-pendiente .alerta-icon { color: var(--accent); }
  .alerta-cumpleanos .alerta-icon { color: #2D7A48; }

  .alerta-text {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.9rem;
    line-height: 1.3;
  }

  .alerta-detalle {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* Próximos turnos */
  .dash-proximos { padding-bottom: 0.5rem; }

  .proximos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .proximo-dia {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.85rem 1rem;
    background: var(--bg);
  }

  .proximo-dia-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.5rem;
  }

  .proximo-dia-fecha {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--text-primary);
  }

  .proximo-dia-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  .proximo-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .proximo-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    gap: 0.1rem 0.6rem;
    padding: 0.4rem 0;
    border-bottom: 1px dashed var(--border);
  }

  .proximo-list li:last-child {
    border-bottom: none;
  }

  .proximo-hora {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    grid-row: 1 / 3;
    align-self: center;
  }

  .proximo-paciente {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    line-height: 1.3;
  }

  .proximo-paciente:hover { color: var(--accent); }

  .proximo-proc {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .dash-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .turno-row { grid-template-columns: auto 1fr; }
    .turno-row .pill { grid-column: 1 / -1; justify-self: start; }
    .kpi-value { font-size: 1.55rem; }
  }
</style>
