---
import DemoAppLayout from './DemoAppLayout.astro';
import { menuItems } from '../data/consultorio';

export interface Props {
  title: string;
  pageTitle: string;
  searchPlaceholder?: string;
  bodyClass?: string;
}

const { title, pageTitle, searchPlaceholder, bodyClass } = Astro.props;

const brand = {
  href: '/demos/consultorio/dashboard',
  mark: 'Ac',
  name: 'Ache',
  sub: 'Odontología',
  ariaLabel: 'Ache Odontología — ir al dashboard',
};

const user = {
  initials: 'MA',
  name: 'Dra. Mercedes Ache',
  role: 'Profesional',
};
---

<DemoAppLayout
  title={title}
  pageTitle={pageTitle}
  searchPlaceholder={searchPlaceholder ?? 'Buscar paciente, presupuesto, turno…'}
  bodyClass={bodyClass}
  brand={brand}
  user={user}
  logoutHref="/demos/consultorio/"
  menuItems={menuItems}
  primaryCount={3}
>
  <slot />
</DemoAppLayout>
